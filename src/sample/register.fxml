<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sample.Controller">
    <children>
        <BorderPane prefHeight="400.0" prefWidth="520.0">
            <left>
                <AnchorPane prefHeight="400.0" prefWidth="215.0" style="-fx-background-color: linear-gradient(to bottom right, #8a7dff, #5a4bff);" BorderPane.alignment="CENTER">
                    <children>
                        <Label alignment="CENTER" layoutX="1.0" layoutY="36.0" prefHeight="27.0" prefWidth="219.0" text="INFORMATION" textFill="WHITE">
                            <font>
                                <Font name="Arial Rounded MT Bold" size="22.0" />
                            </font>
                            <effect>
                                <DropShadow />
                            </effect>
                        </Label>
                        <Text fill="WHITE" layoutX="33.0" layoutY="106.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Welcome to the register page. Here you can put your informations" wrappingWidth="171.47006225585938" />
                        <Text fill="WHITE" layoutX="33.0" layoutY="196.0" strokeType="OUTSIDE" strokeWidth="0.0" text="You already have an account ?">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Text>
                        <Button fx:id="registerHaveAnAccount" layoutX="33.0" layoutY="248.0" mnemonicParsing="false" onAction="#haveAnAccountButton" style="-fx-background-color: #EDE9FE; -fx-background-radius: 20; -fx-label-padding: 2;" text="Have an account" textFill="#8a7dff" />
                    </children>
                </AnchorPane>
            </left>
            <right>
                <AnchorPane prefHeight="400.0" prefWidth="306.0" BorderPane.alignment="CENTER">
                    <children>
                        <Label alignment="CENTER" layoutX="-6.0" layoutY="35.0" prefHeight="27.0" prefWidth="261.0" text="REGISTER FORM" textFill="#8a7dff">
                            <font>
                                <Font name="Arial Rounded MT Bold" size="20.0" />
                            </font>
                        </Label>
                        <Label layoutX="18.0" layoutY="77.0" prefHeight="27.0" prefWidth="110.0" text="Name">
                            <font>
                                <Font name="Arial Unicode MS" size="14.0" />
                            </font>
                        </Label>
                        <TextField fx:id="registerUsernameField" layoutX="16.0" layoutY="112.0" prefHeight="27.0" prefWidth="121.0" promptText="John" style="-fx-background-color: transparent; -fx-border-width: 0 0 1.5 0; -fx-border-color: #8a7dff;">
                            <opaqueInsets>
                                <Insets />
                            </opaqueInsets>
                        </TextField>
                        <Label layoutX="18.0" layoutY="158.0" prefHeight="27.0" prefWidth="83.0" text="Password">
                            <font>
                                <Font name="Arial Unicode MS" size="14.0" />
                            </font>
                        </Label>
                        <PasswordField fx:id="registerPasswordField" layoutX="15.0" layoutY="186.0" prefHeight="27.0" prefWidth="124.0" promptText="123#$%" style="-fx-background-color: transparent; -fx-border-color: #8a7dff; -fx-border-width: 0 0 1.5 0;" />
                        <Label layoutX="18.0" layoutY="225.0" prefHeight="27.0" prefWidth="83.0" text="Confirm Password">
                            <font>
                                <Font name="Arial Unicode MS" size="14.0" />
                            </font>
                        </Label>
                        <PasswordField fx:id="registerConfirmPasswordField" layoutX="21.0" layoutY="252.0" prefHeight="25.0" prefWidth="103.0" promptText="123#$%" style="-fx-background-color: transparent; -fx-border-color: #8a7dff; -fx-border-width: 0 0 1.5 0;" />
                        <Button fx:id="registerHaveAnAccount1" layoutX="19.0" layoutY="343.0" mnemonicParsing="false" onAction="#RegisterUser" style="-fx-background-color: #8a7dff; -fx-background-radius: 20; -fx-label-padding: 2;" text="Register" textFill="WHITE">
