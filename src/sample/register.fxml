                                <Font name="Arial Rounded MT Bold" size="10.0" />
                            </font>
                        </CheckBox>
                        <Label fx:id="registerMessage" layoutX="108.0" layoutY="349.0" prefHeight="21.0" prefWidth="180.0" textFill="#1dd929">
